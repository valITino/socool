# SOCool environment template — copy to .env and fill in only what you need
#
# EVERY value here is a placeholder. Nothing in this file is a real secret.
# .env (without .example) is gitignored; never commit a filled-in copy.
#
# All SOCool-owned environment variables use the SOCOOL_* prefix. Every
# interactive prompt in setup.sh / setup.ps1 has an equivalent env var here
# so that CI runs and returning users can skip prompts entirely.
#
# Rules:
#   1. Do NOT paste real license keys, passwords, or API tokens into .env
#      and then share the file. Treat .env as sensitive.
#   2. If you add a new SOCOOL_* variable, add it here too, with a
#      placeholder and a comment.
#   3. Unset variables fall back to the interactive prompt (when stdin is a
#      tty) or to exit code 64 (when it is not — CI safety).

# ─── Hypervisor selection ───────────────────────────────────────────────
# One of: virtualbox, libvirt
# Leave unset to let setup.* auto-detect per the matrix in ADR-0002.
SOCOOL_HYPERVISOR=

# Allow bridged networking for the lab. Off by default — bridging means
# the lab shares the user's LAN, which undermines isolation. Setting this
# to 1 still requires an interactive confirmation unless SOCOOL_YES=1.
SOCOOL_ALLOW_BRIDGED=0

# Skip all interactive confirmations. Intended for CI. Fails fast if any
# required value is missing instead of prompting. Default 0.
SOCOOL_YES=0

# ─── Vulnerability scanner choice ───────────────────────────────────────
# One of: nessus, openvas, none
# Mutually exclusive at runtime (only one scanner VM boots).
SOCOOL_SCANNER=

# Nessus Essentials activation code. Obtain (free) from
# https://www.tenable.com/products/nessus/nessus-essentials. Required
# only when SOCOOL_SCANNER=nessus.
# Placeholder — replace with your own code at runtime only.
# reserved-for: step-5 (Packer Nessus template)
SOCOOL_NESSUS_ACTIVATION_CODE=CHANGE_ME_AT_RUNTIME

# ─── Windows victim source ──────────────────────────────────────────────
# Where setup.* should source the Windows VM from. One of:
#   eval       — download the Windows 11 Enterprise evaluation ISO from
#                the Microsoft Evaluation Center (90-day free, no key
#                required), then Packer runs an unattended install.
#                This replaces the former 'msdev' option — Microsoft's
#                pre-built developer VMs have been unavailable since
#                October 2024.
#   iso        — use a local Windows ISO path below
SOCOOL_WINDOWS_SOURCE=eval

# Absolute path to a local Windows ISO. Required only when
# SOCOOL_WINDOWS_SOURCE=iso.
SOCOOL_WINDOWS_ISO_PATH=

# ─── Cache and output locations ─────────────────────────────────────────
# Where to cache downloaded ISOs (gitignored, default ./.socool-cache/iso).
# reserved-for: step-5 (Packer ISO download)
SOCOOL_ISO_CACHE_DIR=

# Where Packer writes finished .box files before Vagrant consumes them.
SOCOOL_BOX_OUTPUT_DIR=

# ─── Logging and debugging ──────────────────────────────────────────────
# One of: debug, info, warn, error. Default info.
SOCOOL_LOG_LEVEL=info

# Set to 1 to keep temporary build artefacts around after a failed
# Packer run. Off by default.
# reserved-for: step-5 (Packer tmp handling)
SOCOOL_KEEP_TMP=0

# ─── Reserved / do not use ──────────────────────────────────────────────
# The following names are reserved for internal use and should NOT be set
# manually. Future versions of setup.* may honour or reject them.
#   SOCOOL_INTERNAL_*
