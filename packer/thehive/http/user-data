#cloud-config
# packer/thehive/http/user-data — Subiquity autoinstall; see packer/wazuh/http/user-data for the reference shape.
autoinstall:
  version: 1
  refresh-installer: { update: no }
  locale: en_US.UTF-8
  keyboard: { layout: us }
  network:
    version: 2
    ethernets:
      alleth:
        match: { name: "en*" }
        dhcp4: true
  storage:
    layout: { name: lvm }
  identity:
    hostname: thehive
    realname: Vagrant
    username: vagrant
    # BUILD-ONLY password, rotated by rotate-credentials.sh after
    # provisioning. SHA-512 hash corresponds to
    # 'BUILDONLY-will-be-rotated' — safe to ship in the repo ONLY
    # because it is explicitly overwritten.
    password: "$6$socoolbuild$DyXTUhzJ5EkfuiwRc8Cv9BUILDONLYBUILDONLYBUILDONLYBUILDONLYBUILDONLYBUILDONLYBUILDONLYBUILDONLY00"
  ssh:
    install-server: true
    allow-pw: true
    authorized-keys:
      - "ssh-rsa "
  packages:
    - openssh-server
    - curl
    - ca-certificates
    - sudo
    - gnupg
    - lsb-release
    - jq
    - git
  late-commands:
    - curtin in-target --target=/target -- bash -c 'echo "vagrant ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/vagrant && chmod 0440 /etc/sudoers.d/vagrant'
    - curtin in-target --target=/target -- systemctl enable ssh
